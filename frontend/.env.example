# URL вашего backend (FastAPI), задеплоенного на Railway.
# Для локальной разработки можно поменять на http://localhost:8000
VITE_API_URL=https://honest-reflection-production-3f73.up.railway.app

# Username вашего Telegram-бота (без @). Используется для ссылок-приглашений
# друзей и рефералов — ссылка ведёт в Telegram, а не сразу на сайт.
VITE_BOT_USERNAME=swipeshops_bot

# (Опционально) short name вашего Mini App, заданный в @BotFather через
# /newapp или /myapps. Если указан — ссылки-приглашения открывают приложение
# напрямую с переданным кодом. Если оставить пустым — ссылка ведёт в чат
# с ботом, а код нужно будет ввести вручную на экране «Друзья».
VITE_BOT_APP_SHORT_NAME=
