# Строка подключения к базе данных.
# Локально можно вообще не задавать — будет использован файл swipe.db (SQLite).
# В проде укажите PostgreSQL, например (Railway/Render/любой провайдер):
DATABASE_URL=postgresql://user:password@host:5432/swipeapp

# Токен Telegram-бота — нужен ТОЛЬКО для проверки подписи Telegram Mini App.
# Если приложение работает как обычный сайт (например, на Vercel) — оставьте пустым.
BOT_TOKEN=

# telegram_id пользователей, которым разрешён доступ к /admin/*, через запятую.
# Если пусто — админка открыта всем (удобно для разработки и демо).
ADMIN_IDS=

# Домены, с которых разрешены запросы к API (через запятую). * — разрешить все.
CORS_ORIGINS=*

SECRET_KEY=change-me-in-production
